@page "/Game"
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Miles High Poker! Game Page</PageTitle>

<div class="app-container">
    <h1 class="text-center p-1">Miles High Poker</h1>

    <div id="gameplay-div" class="container">
        <div id="community-card-div">
            @for (int i = 0; i < CommunityCards.Length; i++)
            {
                <div id="community-card-@i"
                     class="community-card-slot"
                     data-slot="@i"
                     @key="i">
                    @if (CommunityCards[i] != null)
                    {
                        var card = CommunityCards[i]!;
                        <img class="card-face-image"
                             src="@ToCardFile(card)"
                             alt="@($"{card.Rank} of {card.Suit}")" />
                    }
                    else
                    {
                        <span>Empty</span>
                    }
                </div>
            }
        </div>

        <div id="pot">
            <p class="text-center m-0">$@Pot</p>
        </div>

        <div id="top-left-player" class="player-seat">
            <div class="player-cards">
                <div id="top-left-player-card-0" class="player-card-slot">
                    <img class="card-back-image" src="@CardBackPath" alt="Face-down card" />
                </div>
                <div id="top-left-player-card-1" class="player-card-slot">
                    <img class="card-back-image" src="@CardBackPath" alt="Face-down card" />
                </div>
            </div>
            <div id="top-left-player-name" class="player-name">Player Name</div>
            <div id="top-left-player-money" class="player-money">$0</div>
        </div>

        <div id="top-right-player" class="player-seat">
            <div class="player-cards">
                <div id="top-right-player-card-0" class="player-card-slot">
                    <img class="card-back-image" src="@CardBackPath" alt="Face-down card" />
                </div>
                <div id="top-right-player-card-1" class="player-card-slot">
                    <img class="card-back-image" src="@CardBackPath" alt="Face-down card" />
                </div>
            </div>
            <div id="top-right-player-name" class="player-name">Player Name</div>
            <div id="top-right-player-money" class="player-money">$0</div>
        </div>

        <div id="bottom-left-player" class="player-seat">
            <div class="player-cards">
                <div id="bottom-left-player-card-0" class="player-card-slot">
                    <img class="card-back-image" src="@CardBackPath" alt="Face-down card" />
                </div>
                <div id="bottom-left-player-card-1" class="player-card-slot">
                    <img class="card-back-image" src="@CardBackPath" alt="Face-down card" />
                </div>
            </div>
            <div id="bottom-left-player-name" class="player-name">Player Name</div>
            <div id="bottom-left-player-money" class="player-money">$0</div>
        </div>

        <div id="bottom-right-player" class="player-seat">
            <div class="player-cards">
                <div id="bottom-right-player-card-0" class="player-card-slot">
                    <img class="card-back-image" src="@CardBackPath" alt="Face-down card" />
                </div>
                <div id="bottom-right-player-card-1" class="player-card-slot">
                    <img class="card-back-image" src="@CardBackPath" alt="Face-down card" />
                </div>
            </div>
            <div id="bottom-right-player-name" class="player-name">Player Name</div>
            <div id="bottom-right-player-money" class="player-money">$0</div>
        </div>

        <div id="current-player-div" class="player-seat current-player-seat">
            <div class="player-cards">
                @for (int i = 0; i < PlayerHand.Length; i++)
                {
                    <div id="current-player-card-@i" class="player-card-slot">
                        @if (PlayerHand[i] != null)
                        {
                            var card = PlayerHand[i]!;
                            <img class="card-face-image"
                                 src="@ToCardFile(card)"
                                 alt="@($"{card.Rank} of {card.Suit}")" />
                        }
                        else
                        {
                            <span>Empty</span>
                        }
                    </div>
                }
            </div>
            <div id="current-player-name" class="player-name">You</div>
            <div id="current-player-money" class="player-money">$0</div>
        </div>

        <div id="current-player-actions" class="text-center">
            <button class="btn btn-danger">
                <span class="action-label">Raise</span>
            </button>
            <button class="btn btn-danger">
                <span class="action-label">Call</span>
            </button>
            <button class="btn btn-danger">
                <span class="action-label">Fold</span>
            </button>
        </div>
    </div>
</div>

<div id="poker-instructions-div" class="container mt-4">
    <h2 class="text-center fw-bolder">How to Play</h2>

    <section class="instruction-section">
        <h3>Game Flow</h3>
        <ul>
            <li>Each player receives 2 private cards ("hole cards").</li>
            <li>Round starts with a betting phase.</li>
            <li>The dealer reveals 3 community cards (the flop), followed by another betting phase.</li>
            <li>The dealer reveals a 4th community card (the turn), followed by another betting phase.</li>
            <li>The dealer reveals a 5th community card (the river), followed by the final betting phase.</li>
            <li>Remaining players go to showdown.</li>
        </ul>
    </section>

    <section class="instruction-section">
        <h3>Betting</h3>
        <ul>
            <li>On your turn, you can usually Fold, Call, or Raise.</li>
            <li><strong>Fold:</strong> Exit the current hand and forfeit chips already committed.</li>
            <li><strong>Call:</strong> Match the current highest bet.</li>
            <li><strong>Raise:</strong> Increase the current highest bet for other players to match.</li>
            <li>Each Raise must be at least the size of the last full Raise.</li>
            <li>Betting round ends when all active players have matched the current bet (or folded).</li>
        </ul>
    </section>

    <section class="instruction-section">
        <h3>Winner</h3>
        <ul>
            <li>Use any 5 cards from your 2 hole cards + 5 community cards.</li>
            <li>Best 5-card poker hand wins the pot.</li>
            <li>If all other players fold, the last active player wins immediately.</li>
            <li>If two or more players tie exactly, the pot is split evenly.</li>
        </ul>
    </section>

    <section class="instruction-section">
        <h3>Special Cases</h3>
        <ul>
            <li><strong>All-in:</strong> A player can bet all remaining chips and can only win the amount they are eligible for.</li>
            <li><strong>Side pots:</strong> If players are all-in for different amounts, extra chips are placed in side pots.</li>
            <li><strong>Disconnected player:</strong> The timer running out will result in a Fold.</li>
            <li><strong>Insufficient chips to call:</strong> Player can go all-in for less than a full call amount.</li>
            <li><strong>Split pot with odd chip:</strong> Extra chip goes to the tied winner first clockwise from the dealer.</li>
        </ul>
    </section>

    <section class="instruction-section">
        <h3>Hand Rankings (Best to Worst)</h3>
        <ol>
            <li><strong>Straight Flush</strong>: Five cards in sequence, all of the same suit.</li>
            <li><strong>Four of a Kind</strong>: Four cards of the same rank.</li>
            <li><strong>Full House</strong>: Three cards of one rank, plus two cards of another.</li>
            <li><strong>Flush</strong>: Any five cards of the same suit, not in sequence.</li>
            <li><strong>Straight</strong>: Five cards in sequence, but not all of the same suit.</li>
            <li><strong>Three of a Kind</strong>: Three cards of the same rank.</li>
            <li><strong>Two Pair</strong>: Two different pairs.</li>
            <li><strong>Pair</strong>: Two cards of the same rank.</li>
            <li><strong>High Card</strong>: If no one has any of the above, the highest card wins.</li>
        </ol>
    </section>
</div>
